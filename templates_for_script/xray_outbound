{
  "tag": "default",
  "protocol": "vless",
  "settings": {
    "vnext": [
      {
        "address": "$VLESS_DOMAIN",
        "port": 443,
        "users": [{ "id": "$XRAY_UUID", "encryption": "none" }]
      }
    ]
  },
  "streamSettings": {
    "network": "xhttp",
    "security": "reality",
    "xhttpSettings": { "mode": "auto" },
    "realitySettings": {
      "serverName": "$VLESS_DOMAIN",
      "fingerprint": "chrome",
      "publicKey": "$XRAY_PBK",
      "shortId": "",
      "spiderX": "/"
    }
  }
}
