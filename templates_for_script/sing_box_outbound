{
    "type": "vless",
    "server": "$VLESS_DOMAIN",
    "server_port": 443,
    "uuid": "$XRAY_UUID",
    "tls": {
        "enabled": true,
        "server_name": "$VLESS_DOMAIN",
        "utls": {
            "enabled": true,
            "fingerprint": "chrome"
        },
        "reality": {
            "enabled": true,
            "public_key": "$XRAY_PBK",
            "short_id": ""
        }
    },
    "transport": {
        "type": "xhttp",
        "path": "/",
        "mode": "auto"
    }
}
